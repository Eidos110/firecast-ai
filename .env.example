# FireCast Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# =============================================================================

# API KEYS - Weather & Geocoding
# =============================================================================

# OpenWeatherMap API Key (get from: https://openweathermap.org/api)
# Without this key, the system will use demo/backup weather data
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Google Maps API Key (optional, for geocoding fallback)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Application Settings
# =============================================================================

# Application Environment: development, staging, production
APP_ENV=development

# Debug Mode: true or false
DEBUG=true

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Model Settings
# =============================================================================

# Device for ML models: auto, cpu, cuda
ML_DEVICE=auto

# CNN Dropout Rate (must match trained model)
CNN_DROPOUT=0.3

# Ensemble Target Recall
TARGET_RECALL=0.80

# Data Settings
# =============================================================================

# Data split ratio (0.9 = 90% training, 10% testing)
TRAIN_SPLIT=0.9

# Temporal feature parameters
LAG_DAYS=3
ROLLING_WINDOW=7

# Frontend Settings (Streamlit)
# =============================================================================

# Streamlit Server Port
STREAMLIT_PORT=8501

# Streamlit Server Address
STREAMLIT_ADDRESS=localhost

# Enable Demo Mode (when true, uses synthetic data if APIs fail)
# SECURITY: Set to false in production to ensure real model predictions
ENABLE_DEMO_MODE=false

# API Settings (FastAPI)
# =============================================================================

# API Host
API_HOST=0.0.0.0

# API Port
API_PORT=8000

# API Key for protected endpoints (generate a secure random string)
API_SECRET_KEY=your_secure_api_secret_key_here

# Enable CORS (set to false in production if not needed)
ENABLE_CORS=true

# Database (Optional - for future use)
# =============================================================================

# DATABASE_URL=postgresql://user:password@localhost:5432/firecast

# Cache Settings
# =============================================================================

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# Enable hexagon precomputation
ENABLE_HEX_PRECOMPUTE=true
